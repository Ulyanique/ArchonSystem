# Ollama настройки
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-v3.1:671b-cloud

# DeepSeek настройки (если используете облачный API)
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter настройки (для использования моделей через OpenRouter, включая Aurora Alpha)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/aurora-alpha
# Модель для генерации изображений (портреты персонажей)
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# RouterAI настройки (альтернативный провайдер)
ROUTERAI_API_KEY=your_routerai_api_key_here
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
ROUTERAI_MODEL=openai/gpt-3.5-turbo

# Выбор модели по умолчанию (ollama, deepseek, openrouter или routerai)
DEFAULT_LLM_PROVIDER=ollama

# Порт backend
BACKEND_PORT=8000

# Режим отладки (true/false). В production оставьте false — в ответах API не будет текста исключений.
DEBUG=false

# Разрешённые CORS-истоки через запятую (для фронта при другом порте/домене)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# RAG (векторный поиск): модель эмбеддингов для русского/мультиязычного поиска по главам и заметкам.
# Не задано = используется модель по умолчанию (paraphrase-multilingual-MiniLM-L12-v2). Задайте none или chromadb, чтобы отключить и использовать встроенные эмбеддинги ChromaDB.
# RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Опционально: токен Hugging Face (меньше лимиты при скачивании моделей, быстрее загрузка). Создать на https://huggingface.co/settings/tokens
# HF_TOKEN=your_hf_token_here
# Убрать предупреждение про symlinks на Windows (кэш моделей без режима разработчика):
# HF_HUB_DISABLE_SYMLINKS_WARNING=1
